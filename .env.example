# Local development — points to beta schema
# Copy this to .env.local and fill in your values
# Never commit .env.local to the repo

VITE_SUPABASE_URL=https://adojihtjkfhozwbxfjae.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SCHEMA=beta
VITE_ENV=development

# ─── Playwright e2e ───────────────────────────────────────────────────────
# Only needed when running `npm run test:e2e`. Service role key bypasses RLS;
# used by e2e/global-setup.js to wipe auth users + beta tables between runs.
# Grab it from: Supabase Dashboard → Project Settings → API → service_role.
# NEVER commit this key and NEVER expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Override if you run vite on a non-default port. Default: http://localhost:5173
# E2E_BASE_URL=http://localhost:5173

# ─── Photo-scan Edge Function (server-only) ──────────────────────────────
# These are NOT used by the Vite client. They are picked up by
# `supabase functions serve` when emulating the `scan-clothing-tag`
# function locally. In production they're set with `supabase secrets set`
# and never materialize in the browser bundle.
#
# Generate a key: https://console.anthropic.com/ → API Keys
# Deploy to Supabase:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set SCAN_DAILY_LIMIT=50        # optional, default 50
# Deploy function:
#   supabase functions deploy scan-clothing-tag
#
# For local emulation, copy this file to supabase/.env (or export in your
# shell) and run: supabase functions serve scan-clothing-tag --env-file supabase/.env
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# SCAN_DAILY_LIMIT=50
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
